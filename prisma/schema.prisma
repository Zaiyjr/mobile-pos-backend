generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// ==========================================
// 1. ລະບົບຈັດການຜູ້ໃຊ້ ແລະ ສິດ (RBAC - Model Role)
// ==========================================
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // ບ່ອນເກັບລະຫັດຜ່ານພະນັກງານ (Bcrypt Hash)
  name      String   // ຊື່ແທ້ຂອງພະນັກງານ
  roleId    Int      // ຜູກ ID ໄປຫາ Table Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean @default(false)
  deletedAt DateTime?

  role      Role     @relation(fields: [roleId], references: [id])
  orders    Order[]  // ປະຫວັດບິນຂາຍທີ່ພະນັກງານຄົນນີ້ເປັນຄົນອອກ
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique // ເຊັ່ນ: "ADMIN", "EMPLOYEE", "CASHIER"
  users     User[]   
}

// ==========================================
// 2. ລະບົບລູກຄ້າ & ສະມາຊິກ (Customer)
// ==========================================
model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  points    Int      @default(0) // ລະບົບສະສົມຄະແນນຂອງຮ້ານ
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean @default(false)
  deletedAt DateTime?

  orders    Order[]
}

// ==========================================
// 3. ໝວດໝູ່ ແລະ ຍີ່ຫໍ້ (Category & Brand)
// ==========================================
model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique // ເຊັ່ນ: Smartphone, Laptop
  products Product[]

}

model Brand {
  id       Int       @id @default(autoincrement())
  name     String    @unique // ເຊັ່ນ: Apple, Samsung
  products Product[]
  
}

// ==========================================
// 4. ລະບົບສິນຄ້າ ແລະ ສະຕັອກ (Product & Stock)
// ==========================================
model Product {
  id          Int              @id @default(autoincrement())
  name        String
  description String?          @db.Text
  categoryId  Int
  brandId     Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  isDeleted Boolean @default(false)
  deletedAt DateTime?

  category    Category         @relation(fields: [categoryId], references: [id])
  brand       Brand            @relation(fields: [brandId], references: [id])
  images      ProductImage[]
  specs       ProductSpec[]
  variants    ProductVariant[]
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  imageUrl  String  @db.Text
  isMain    Boolean @default(false) // ຮູບຫຼັກທີ່ຈະໄປສະແດງໜ້າ POS
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ລຸ້ນຍ່ອຍ (ແຍກສີ, ລາຄາ ແລະ ສະຕັອກລວມ)
model ProductVariant {
  id            Int            @id @default(autoincrement())
  productId     Int
  color         String
  sku           String         @unique 
  price         Decimal        @db.Decimal(10, 2)
  stockQuantity Int            @default(0) // ຈຳນວນສະຕັອກລວມຂອງລຸ້ນນີ້

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  stockItems    StockItem[]    // ຂໍ້ມູນເລກ IMEI ແຕ່ລະເຄື່ອງ
  isDeleted Boolean @default(false)
  deletedAt DateTime?
}

// ຕາຕະລາງເກັບເລກ IMEI / Serial Number ແຕ່ລະເຄື່ອງ (ສຳຄັນຫຼາຍສຳລັບຮ້ານມືຖື)
model StockItem {
  id             Int            @id @default(autoincrement())
  variantId      Int
  serialNumber   String         @unique // ເລກ IMEI 15 ຫຼັກ ຫຼື S/N ຂອງເຄື່ອງນັ້ນໆ
  status         String         @default("AVAILABLE") // AVAILABLE, SOLD, CLAIM

  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  orderItemItems OrderItemItem[]
}

// ==========================================
// 5. ລະບົບ Specifications (ສະເປັກສິນຄ້າ)
// ==========================================
model SpecAttribute {
  id    Int           @id @default(autoincrement())
  name  String        @unique // ເຊັ່ນ: RAM, Storage, CPU
  specs ProductSpec[]
}

model ProductSpec {
  id          Int           @id @default(autoincrement())
  productId   Int
  attributeId Int
  value       String        // ເຊັ່ນ: 8GB, 256GB

  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute   SpecAttribute @relation(fields: [attributeId], references: [id])
}

// ==========================================
// 6. ລະບົບການຂາຍ (Order Only)
// ==========================================
model Order {
  id          Int         @id @default(autoincrement())
  employeeId  Int         // ID ພະນັກງານຄົນຂາຍ (User ID)
  customerId  Int?        // ID ລູກຄ້າ (ໃສ່ ຫຼື ບໍ່ໃສ່ກໍໄດ້)
  totalAmount Decimal     @db.Decimal(10, 2) // ຍອດລວມທັງໝົດຂອງບິນນີ້
  status      String      @default("PAID") // PAID (ຈ່າຍແລ້ວ), CANCELLED (ຍົກເລີກ)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  employee    User        @relation(fields: [employeeId], references: [id])
  customer    Customer?   @relation(fields: [customerId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id          Int            @id @default(autoincrement())
  orderId     Int
  variantId   Int
  quantity    Int
  priceAtTime Decimal        @db.Decimal(10, 2) // ເກັບລາຄາຕອນທີ່ຂາຍ

  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  soldItems   OrderItemItem[] // ຜູກວ່າບິນນີ້ຂາຍເຄື່ອງເລກ IMEI ໃດອອກໄປ
}

// Junction Table ຜູກບິນກັບເລກ IMEI ທີ່ຂາຍອອກ
model OrderItemItem {
  orderItemId Int
  stockItemId Int

  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])

  @@id([orderItemId, stockItemId])
}